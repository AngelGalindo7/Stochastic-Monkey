OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=

GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

LIGHTPANDA_BIN=
HEADFUL=false

# Grafana Cloud Tempo (OTLP traces). Get these from Grafana Cloud > Connections > Tempo > "Send traces (OTLP)".
# Region prefix in the URL depends on which stack the account lives on (e.g. prod-us-central-0).
GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-prod-us-central-0.grafana.net/otlp/v1/traces
GRAFANA_INSTANCE_ID=
GRAFANA_API_TOKEN=
